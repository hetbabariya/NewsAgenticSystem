# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/newsagent

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_WEBHOOK_SECRET_TOKEN=random_secret_string

# LLM API Keys (Comma-separated lists)
GROQ_API_KEYS=gsk_key1,gsk_key2
OPENROUTER_API_KEYS=sk-or-v1-key1,sk-or-v1-key2

# Web Search & Sources
TAVILY_API_KEYS=tvly-key1,tvly-key2

# Other Source Keys (Optional)
NEWSAPI_KEY=...
GITHUB_TOKEN=...

# X (Twitter) Keys
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_TOKEN_SECRET=...

# Reddit Keys
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=newsagent:v1.0 (by /u/your_username)

# Model Overrides (Optional - defaults already set in code)
# MODEL_COORDINATOR=llama-3.3-70b-versatile
# MODEL_SUMMARIZER=meta-llama/llama-3-8b-instruct:free

# Other Configurations
ENV=development
RENDER_EXTERNAL_URL=https://your-ngrok-url.ngrok-free.app
