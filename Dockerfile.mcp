FROM supercorp/supergateway:latest

# install node and npm (Alpine package manager)
RUN apk add --no-cache nodejs npm \
    && npm install -g tavily-mcp

# MCP config
ENV MCP_OUTPUT_TRANSPORT=sse
ENV MCP_SSE_PATH=/sse
ENV MCP_MESSAGE_PATH=/message
ENV MCP_HTTP_PATH=/mcp

# default command
ENV MCP_STDIO_CMD="tavily-mcp"

ENTRYPOINT ["sh", "-c", "echo \"Starting supergateway with command: $MCP_STDIO_CMD on port ${PORT:-8000}\"; exec supergateway --stdio \"$MCP_STDIO_CMD\" --port \"${PORT:-8000}\" --outputTransport \"${MCP_OUTPUT_TRANSPORT:-sse}\" --ssePath \"${MCP_SSE_PATH:-/sse}\" --messagePath \"${MCP_MESSAGE_PATH:-/message}\" --streamableHttpPath \"${MCP_HTTP_PATH:-/mcp}\" --cors --healthEndpoint /healthz --baseUrl \"https://${RENDER_EXTERNAL_HOSTNAME:-localhost}\""]