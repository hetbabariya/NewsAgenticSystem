FROM supercorp/supergateway:latest

ENV MCP_OUTPUT_TRANSPORT=sse
ENV MCP_SSE_PATH=/sse
ENV MCP_MESSAGE_PATH=/message
ENV MCP_HTTP_PATH=/mcp

# Required:
#   MCP_STDIO_CMD: command to start an MCP stdio server (example: npx -y tavily-mcp@0.1.4)
# Render provides PORT automatically.
CMD ["sh", "-c", "supergateway --stdio \"${MCP_STDIO_CMD}\" --port ${PORT:-8000} --outputTransport ${MCP_OUTPUT_TRANSPORT:-sse} --ssePath ${MCP_SSE_PATH:-/sse} --messagePath ${MCP_MESSAGE_PATH:-/message} --streamableHttpPath ${MCP_HTTP_PATH:-/mcp} --cors --healthEndpoint /healthz"]
